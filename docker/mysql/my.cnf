# ===========================================
# docker/mysql/my.cnf - MySQL設定（ローカル開発用）
# ===========================================

[mysqld]
# 文字セット設定
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# 日本語検索改善
ft_min_word_len = 1
innodb_ft_min_token_size = 1

[mysql]
default-character-set = utf8mb4

[client]
default-character-set = utf8mb4
