{
  "name": "astro-dev",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "// === Linterチェックコマンド ===": "",
    "lint": "eslint 'src/**/*.{js,ts,astro,json}' --fix",
    "lint:css": "stylelint 'src/**/*.scss' --fix",
    "lint:markup": "markuplint 'htdocs/**/*.{html,php}' --fix --config .markuplintrc",
    "lint:all": "run-p lint lint:css lint:markup",
    "lint:ci": "run-s lint:js:ci lint:css:ci lint:markup:ci",
    "lint:js:ci": "eslint 'src/**/*.{js,ts,astro,json}' --format json --output-file eslint-report.json",
    "lint:css:ci": "stylelint 'src/**/*.scss' --formatter json > stylelint-report.json",
    "lint:markup:ci": "markuplint 'htdocs/**/*.{html,php}' -f JSON > markuplint-report.json",
    "// === Playwrightチェックコマンド ===": "",
    "test:a11y:setup": "npx playwright install --with-deps",
    "test:a11y": "playwright test",
    "test:a11y:ui": "playwright test --ui",
    "test:a11y:report": "playwright show-report",
    "// === Lighthouseチェックコマンド ===": "",
    "lighthouse:clean": "rm -rf .lighthouseci",
    "lighthouse": "npm run lighthouse:clean && lhci autorun && npm run lighthouse:open",
    "lighthouse:ci": "npm run lighthouse:clean && lhci autorun",
    "lighthouse:collect": "lhci collect",
    "lighthouse:assert": "lhci assert",
    "lighthouse:open": "open .lighthouseci/*.html 2>/dev/null || xdg-open .lighthouseci/*.html 2>/dev/null || start .lighthouseci/*.html 2>/dev/null || true"
  },
  "browserslist": [
    "last 2 version",
    "not dead"
  ],
  "dependencies": {
    "@astrojs/compiler-rs": "^0.1.10",
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "astro": "^6.4.6",
    "axe-core": "^4.12.1"
  },
  "devDependencies": {
    "@acab/reset.css": "^0.11.0",
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@markuplint/astro-parser": "^4.18.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/jquery": "^3.5.34",
    "@types/node": "^22.19.21",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "astro-relative-links": "^0.4.2",
    "chokidar-cli": "^3.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^16.5.0",
    "jquery": "^3.7.1",
    "markuplint": "^4.18.3",
    "npm-run-all2": "^7.0.2",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "sass": "^1.101.0",
    "sharp": "^0.34.5",
    "stylelint": "^16.26.1",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-recess-order": "^6.1.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite-plugin-sass-glob-import": "^6.0.3"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ]
  }
}
